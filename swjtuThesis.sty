% 图表题注格式宏包
\usepackage{caption}
%\captionsetup{labelformat=simple, labelsep=space, font=bf}
%\captionsetup{labelformat=simple, labelsep=quad, labelfont=bf, textfont=normalfont}

%将图表标签和标题改成黑体五号
\DeclareCaptionLabelSeparator{twospace}{\ ~}
\captionsetup{labelformat=simple, labelsep=twospace, font={sf,small}}

% 算法宏包
\usepackage{algorithmic}
