\usepackage{mathrsfs} % 不同于\mathcal or \mathfrak 之类的英文花体字体
% \usepackage{mathtools}
\usepackage{wasysym}  % 绘制版权部分的方框和打勾方框
\usepackage{cases} % cases环境
