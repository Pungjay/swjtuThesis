% 表格制作常用宏包

\usepackage{multirow} % 表格中支持跨行

\usepackage{dcolumn} % 表格中数字按小数点对齐
\newcolumntype{d}[1]{D{.}{.}{#1}}

\usepackage{booktabs} % 使用三线表：toprule，midrule，bottomrule

